# Root-level ignores for the ARMIS monorepo.
# Per-project ignores live inside armini/, ai-gateway/, mcp/, and mock-backend/.

# Root-level deps (only `concurrently` for the top-level `npm run dev` orchestrator)
/node_modules/
/package-lock.json

# Expo cache at root
/.expo/

# OS / editor
.DS_Store
Thumbs.db
*.log

# Local env files
.env
.env.local
.env.*.local
